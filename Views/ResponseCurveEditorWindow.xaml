<Window x:Class="KBMJoyAssist.ResponseCurveEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keyboard Response Curve"
        Height="470"
        Width="620"
        MinHeight="430"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Custom keyboard response curve"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#242424"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                BorderBrush="#CFCFCF"
                BorderThickness="1"
                Background="White">
            <Canvas x:Name="CurveCanvas"
                    Height="220"
                    ClipToBounds="True"/>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="Curve points"
                   FontSize="12"
                   Foreground="#333"
                   Margin="0,12,0,4"/>

        <StackPanel Grid.Row="3">
            <TextBox x:Name="CurveTextBox"
                     Height="32"
                     VerticalContentAlignment="Center"
                     TextChanged="CurveTextBox_TextChanged"/>
            <TextBlock Text="Format: input,output; input,output. Values are 0.00 to 1.00. Example: 0,0;0.3,0.12;0.7,0.82;1,1"
                       FontSize="11"
                       Foreground="#666"
                       TextWrapping="Wrap"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Reset"
                    Width="82"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="ResetButton_Click"/>
            <Button Content="Cancel"
                    Width="82"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"/>
            <Button Content="Save"
                    Width="82"
                    Height="30"
                    Background="#2E7D32"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
